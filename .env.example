# --- MEXC credentials (use a key with WITHDRAWALS DISABLED) ---
MEXC_API_KEY=your_mexc_public_api_key
MEXC_API_SECRET=your_mexc_private_secret_key

# --- Mode ---
TRADE_MODE=DRY_RUN          # DRY_RUN or LIVE
MARKET_TYPE=spot            # spot (long-only) or futures (long + short)
ALLOW_SHORTS=false          # honoured only when MARKET_TYPE=futures

# --- Universe ---
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TIMEFRAME=15m

# --- Capital & risk ---
INITIAL_TEST_BUDGET=10.0    # starting equity for the simulated ledger
MAX_BUDGET=10.0             # hard cap on capital deployed at once (USDT)
MAX_RISK_PER_TRADE=0.02     # fraction of equity risked per trade
STOP_LOSS_PCT=0.02          # stop distance as a fraction of entry price
REWARD_RISK_RATIO=2.5       # take-profit = this multiple of the stop distance
LEVERAGE=1                  # futures only

# --- Forecast model ---
CHRONOS_MODEL=amazon/chronos-t5-tiny
FORECAST_HORIZON=5
FORECAST_ALPHA=0.005        # bias threshold buffer (0.5%)
STRUCTURE_WINDOW=5          # swing detection radius in bars
CONTEXT_LENGTH=200          # candles fed to the model / structure parser

# --- Costs (used by the simulator and edge checks) ---
TAKER_FEE=0.0005
SLIPPAGE=0.0005

# --- Decision engine: signal weights (relative; need not sum to 1) ---
WEIGHT_STRUCTURE=0.30
WEIGHT_FORECAST=0.25
WEIGHT_MOMENTUM=0.20
WEIGHT_VOLATILITY=0.05
WEIGHT_SENTIMENT=0.15       # Fear & Greed
WEIGHT_NEWS=0.05            # only used if ENABLE_NEWS_SENTIMENT=true
REQUIRE_STRUCTURE_ALIGNMENT=false  # false = EV ensemble decides; true = structure hard-gates direction
MIN_CONVICTION=0.35        # min aggregate confidence to open a trade
MIN_EXPECTED_VALUE=0.001   # min expected value (fraction of price) to trade

# --- Momentum / volatility ---
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
ATR_PERIOD=14
ATR_MAX_PCT=0.05           # ATR above this fraction of price -> no-trade veto

# --- Sentiment ---
FEAR_GREED_URL=https://api.alternative.me/fng/?limit=1
FEAR_GREED_CONTRARIAN=true # flip the signal at extreme greed/fear (>=80 / <=20)
ENABLE_NEWS_SENTIMENT=false # true loads a HuggingFace crypto/finance model
NEWS_MODEL=ElKulako/cryptobert
NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
NEWS_MAX_HEADLINES=20

# --- Loop ---
POLL_SECONDS=900            # 15 minutes
DB_PATH=crypto_agent.db

# --- Risk guardrails ---
USE_ATR_STOPS=false           # true = stop distance adapts to volatility (ATR * mult)
ATR_STOP_MULT=1.5
MIN_STOP_PCT=0.005
MAX_STOP_PCT=0.05
MAX_OPEN_POSITIONS=2          # crypto pairs are correlated; cap total open risk
DAILY_MAX_LOSS_PCT=0.05       # halt new entries after losing 5% of equity in a day
COOLDOWN_SECONDS=3600         # no re-entry on a symbol for 1h after a stop-out
